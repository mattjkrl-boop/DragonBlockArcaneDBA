{
	"schemaVersion": 1,
	"id": "dragonblockarcanedba",
	"version": "${version}",
	"name": "Dragon Block Arcane DBA",
	"description": "A comprehensive Dragon Ball themed mod for Fabric, covering races, attributes, Ki energy, and dynamic transformations.",
	"authors": [
		"Matt",
		"Carter"
	],
	"contact": {
		"homepage": "https://fabricmc.net/"
	},
	"license": "Proprietary",
	"icon": "assets/dragonblockarcanedba/icon.png",
