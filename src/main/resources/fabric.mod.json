		"main": [
			"com.dragonblockarcanedba.DragonBlockArcaneDBA"
		],
		"client": [
			"com.dragonblockarcanedba.client.DragonBlockArcaneDBAClient"
		]
	},
	"mixins": [
		"dragonblockarcanedba.mixins.json",
		{
			"config": "dragonblockarcanedba.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~26.2",
		"java": ">=25",
		"fabric-api": "*",
		"geckolib": "*"
